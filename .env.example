# =============================================================================
# KoAkademy Development Environment Configuration
# =============================================================================
# Copy this file to .env and configure for your development environment

# Note: For Docker Compose environments:
# - Use service names (e.g., 'pgsql', 'redis') for container-to-container communication
# - Use 'localhost' or '127.0.0.1' for direct local access

# Application Settings
APP_NAME="KoAkademy"
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Asia/Manila
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# Application URL - Set to your local domain
APP_URL=http://localhost

# Generate with: php artisan key:generate --show
APP_KEY=

# ======================== DATABASE ========================
DB_CONNECTION=sqlite
# DB_HOST=pgsql
# DB_PORT=5432
# DB_DATABASE=koakademy
# DB_USERNAME=sail
# DB_PASSWORD=
# DB_DATABASE_TESTING=koakademy-testing
# AUTO_MIGRATE=true

# ======================== CACHE & REDIS ========================
CACHE_STORE=database
CACHE_PREFIX=
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_PDF_QUEUE_DB=3

REDIS_QUEUE_RETRY_AFTER=90
REDIS_PDF_QUEUE_RETRY_AFTER=7200

# ======================== QUEUE ========================
# Use 'sync' for development (processes jobs immediately)
# Change to 'redis' for async job processing
# Change to 'horizon' if using Laravel Horizon
QUEUE_CONNECTION=sync

# ======================== MAIL ========================
# Development: Use 'log' or 'mailpit'
# Mailpit UI: http://mailpit.local.test:8025
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=info@koakademy.edu
MAIL_FROM_NAME="${APP_NAME}"

# ======================== BROADCASTING & REALTIME ========================
BROADCAST_CONNECTION=log
BROADCAST_DRIVER=log
PUSHER_APP_ID="1801608"
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER="ap1"
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ======================== FILE STORAGE ========================
# MinIO Configuration (for S3-like local storage)
# MinIO: http://minio.local.test:9000
# MinIO Console: http://minio-console.local.test:8900
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=koakademy
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=http://localhost:9000/dccpadmin

# ======================== PDF RENDERING ========================
# Using Cloudflare Browser Rendering (headless Chrome via API)
# https://spatie.be/docs/laravel-pdf/v2/drivers/using-the-cloudflare-driver
LARAVEL_PDF_DRIVER=cloudflare
LARAVEL_PDF_PRODUCTION_DRIVER=cloudflare
LARAVEL_PDF_STAGING_DRIVER=cloudflare
LARAVEL_PDF_LOCAL_DRIVER=cloudflare

# Fallback order by environment profile
LARAVEL_PDF_PRODUCTION_FALLBACK=dompdf
LARAVEL_PDF_STAGING_FALLBACK=dompdf
LARAVEL_PDF_LOCAL_FALLBACK=dompdf

# Rollback target if remote rendering provider is unavailable
LARAVEL_PDF_ROLLBACK_DRIVER=dompdf

# Cloudflare Browser Rendering credentials (required for cloudflare driver)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ======================== IMAGE PROCESSING ========================
# Leave empty to use autodiscovery or configure for external headless Chrome
CHROME_BIN=
CHROME_ARGS="--no-sandbox --disable-dev-shm-usage --disable-gpu --headless --disable-extensions"
IMAGE_DRIVER=gd
IMAGE_QUALITY=90
IMAGE_ALLOW_SVG=true

# ======================== LOGGING ========================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug
ACTIVITY_LOG_ENABLED=true
DEBUGBAR_ENABLED=true

# ======================== LARAVEL OCTANE & FRANKENPHP ========================
OCTANE_SERVER=frankenphp
OCTANE_WORKERS=auto
OCTANE_MAX_REQUESTS=500
OCTANE_LOG_LEVEL=info
OCTANE_HTTPS=false

# ======================== DEBUGGING ========================
# Xdebug Configuration
SAIL_XDEBUG_MODE=off
SAIL_XDEBUG_CONFIG=client_host=127.0.0.1

# Feature Flags
TELESCOPE_ENABLED=true
TELESCOPE_ONLY_LOCALHOST=false
HORIZON_ENABLED=true
HORIZON_PREFIX=horizon:
PULSE_ENABLED=true
PULSE_INGEST_DRIVER=redis
PULSE_STORAGE_DRIVER=database

# ======================== DOCKER COMPOSE ========================
WWWGROUP=1000
WWWUSER=1000
FORWARD_DB_PORT=5432
FORWARD_REDIS_PORT=6379
FORWARD_MINIO_PORT=9000
FORWARD_MINIO_CONSOLE_PORT=8900
FORWARD_MAILPIT_PORT=1025
FORWARD_MAILPIT_DASHBOARD_PORT=8025
VITE_PORT=5173

# ======================== LOCAL DOMAINS ========================
# These domains are configured in Traefik and /etc/hosts
# After setup, these should be accessible in your browser
PORTAL_HOST=localhost
ADMIN_HOST=admin.koakademy.test
MAILPIT_HOST=mailpit.local.test
MINIO_HOST=minio.local.test
MINIO_CONSOLE_HOST=minio-console.local.test

# ======================== VITE ========================
VITE_APP_NAME="${APP_NAME}"

# ======================== ONBOARDING ========================
ONBOARDING_FORCE_ON_LOGIN=false

# ======================== API & INTEGRATIONS ========================
RESEND_API_KEY=

# ======================== SANITY CMS ========================
# Sanity Headless CMS Configuration
# Get these values from your Sanity project at https://www.sanity.io/manage
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_TOKEN=
SANITY_API_VERSION=2023-05-03
SANITY_USE_CDN=false

# ======================== API ENDPOINT ========================
API_SERVICE_HOST=http://localhost
API_SERVICE_TIMEOUT=30
