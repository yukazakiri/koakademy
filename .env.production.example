# =============================================================================
# KoAkademy Production Environment Configuration
# =============================================================================
# Copy this file to .env and configure for your production environment

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="KoAkademy"
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Asia/Manila
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# Generate with: php artisan key:generate --show
APP_KEY=

# -----------------------------------------------------------------------------
# Laravel Octane & FrankenPHP
# -----------------------------------------------------------------------------
OCTANE_SERVER=frankenphp
OCTANE_WORKERS=auto
OCTANE_MAX_REQUESTS=500
OCTANE_LOG_LEVEL=info
OCTANE_HTTPS=false

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=koakademy
DB_USERNAME=user
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Cache & Session
# -----------------------------------------------------------------------------
CACHE_STORE=redis
CACHE_PREFIX=
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -----------------------------------------------------------------------------
# Queue
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=redis

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# -----------------------------------------------------------------------------
# Mail
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=info@koakademy.edu
MAIL_FROM_NAME="${APP_NAME}"
# -----------------------------------------------------------------------------
# Broadcasting
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=log
BROADCAST_DRIVER=log

# -----------------------------------------------------------------------------
# Filesystem / S3 (MinIO)
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=r2

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=koakademy
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=

# MinIO Configuration


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Chrome for PDF Generation
# -----------------------------------------------------------------------------
CHROME_BIN=/usr/bin/google-chrome-stable
CHROME_ARGS="--no-sandbox --disable-dev-shm-usage --disable-gpu --headless --disable-extensions"

# -----------------------------------------------------------------------------
# Auto-migrate (set to false for production safety)
# -----------------------------------------------------------------------------
AUTO_MIGRATE=true
RUN_MIGRATIONS=true
 # PRODUCTION_SEEDERS=RolesSeeder,BackupPermissionSeeder

# -----------------------------------------------------------------------------
# Docker Compose Ports (for port mapping)
# -----------------------------------------------------------------------------
APP_PORT=80
DB_EXPOSE_PORT=5432
REDIS_EXPOSE_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=8900

# -----------------------------------------------------------------------------
# Laravel Telescope (optional, for debugging)
# -----------------------------------------------------------------------------
TELESCOPE_ENABLED=false

# -----------------------------------------------------------------------------
# Laravel Horizon
# -----------------------------------------------------------------------------
HORIZON_PREFIX=horizon:

# -----------------------------------------------------------------------------
# Laravel Pulse
# -----------------------------------------------------------------------------
PULSE_ENABLED=true
PULSE_INGEST_DRIVER=redis
PULSE_STORAGE_DRIVER=database

# -----------------------------------------------------------------------------
# Vite (for asset compilation - only needed during build)
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# R2 Configurations
# -----------------------------------------------------------------------------
R2_URL=
R2_ENDPOINT=
R2_BUCKET=
R2_SECRET_ACCESS_KEY=
R2_ACCESS_KEY_ID=

# -----------------------------------------------------------------------------
# Docker Compose User Configuration
# -----------------------------------------------------------------------------
WWWGROUP=1000
WWWUSER=1000

# -----------------------------------------------------------------------------
# Local domain hostnames for Traefik routing (used in docker compose labels)
# -----------------------------------------------------------------------------
PORTAL_HOST=portal.koakademy.edu
ADMIN_HOST=admin.koakademy.edu
MAILPIT_HOST=mailpit.local.com
MINIO_HOST=minio.local.com
MINIO_CONSOLE_HOST=minio-console.local.com

PUSHER_APP_ID="1801608"
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER="ap1"
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

SANITY_PROJECT_ID=4pzjiopf
SANITY_DATASET=production
SANITY_API_TOKEN=
SANITY_API_VERSION=2025-12-29

SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700

MEILISEARCH_NO_ANALYTICS=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://portal.koakademy.edu/integrations/google/callback
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0



ONBOARDING_FORCE_ON_LOGIN=false

DATABASE_SYNC_DATABASE_DRIVER=postgres


DATABASE_SYNC_POSTGRES_CREATE_MISSING_TABLES=true
DATABASE_SYNC_POSTGRES_PG_DUMP_BINARY=/usr/lib/postgresql/17/bin/pg_dump
DATABASE_SYNC_POSTGRES_SCHEMA_DUMP_FLAGS="--schema-only --no-owner --no-privileges"
